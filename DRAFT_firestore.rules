rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (Phase 3)
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "jinamolsom@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isNotBanned() {
      return isAuthenticated() && 
        (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == false);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Helpers (Phase 4)
    // ===============================================================

    function isValidUser(data, userId) {
      return data.uid == userId &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.phoneNumber is string && data.phoneNumber.size() <= 15 &&
             data.balance is number &&
             data.role in ['user', 'admin'] &&
             data.createdAt is string &&
             (!('isBanned' in data) || data.isBanned is bool) &&
             (!('coins' in data) || data.coins is number) &&
             (!('streak' in data) || data.streak is number) &&
             (!('referralCount' in data) || data.referralCount is number);
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.reward is number && data.reward >= 0 &&
             data.type in ['video', 'download', 'form'] &&
             data.difficulty in ['easy', 'medium', 'hard'];
    }

    function isValidSubmission(data) {
      return data.userId == request.auth.uid &&
             isValidId(data.taskId) &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.reward is number &&
             data.reward >= 0 &&
             data.submittedAt is string;
    }

    function isValidWithdrawal(data) {
      return data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 200 &&
             data.method in ['UPI', 'Paytm'] &&
             data.details is string && data.details.size() <= 200 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.requestedAt is string;
    }

    function isValidTransaction(data) {
      return data.userId is string &&
             data.amount is number &&
             data.type in ['credit', 'debit'] &&
             data.category in ['task', 'referral', 'bonus', 'spin', 'withdrawal', 'mystery_box', 'purchase', 'ad_reward', 'affiliate'] &&
             data.timestamp is string;
    }

    function isValidAppSettings(data) {
      return data.isAppLive is bool &&
             data.maintenanceMode is bool &&
             data.dailyBonusAmount is number &&
             data.maxSpinReward is number &&
             data.minSpinReward is number &&
             data.mysteryBoxFreeMax is number &&
             data.mysteryBoxPaidMax is number &&
             data.mysteryBoxPaidPrice is number &&
             data.winProbability is number &&
             data.taskRewardMultiplier is number;
    }

    // ===============================================================
    // Domain Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      isValidUser(incoming(), userId) && 
                      incoming().role == 'user' &&
                      incoming().balance == 0;
      allow update: if (isAdmin() && isValidUser(incoming(), userId)) ||
                      (isOwner(userId) && 
                       isNotBanned() &&
                       isValidUser(incoming(), userId) &&
                       incoming().role == existing().role &&
                       incoming().createdAt == existing().createdAt &&
                       // Allow updating balance, coins, streak etc but NOT role or isBanned
                       incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'coins', 'streak', 'lastCheckIn', 'spinsLeft', 'lastSpinDate', 'lastBoxOpenDate', 'boxesOpenedToday', 'adsWatchedToday', 'displayName', 'photoURL'])
                      );
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidTask(incoming());
    }

    match /submissions/{submissionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isNotBanned() && 
                      isValidSubmission(incoming()) && 
                      exists(/databases/$(database)/documents/tasks/$(incoming().taskId));
      allow update: if isAdmin() && isValidSubmission(incoming());
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isNotBanned() && 
                      isValidWithdrawal(incoming()) && 
                      incoming().status == 'pending';
      allow update: if isAdmin() && isValidWithdrawal(incoming());
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if (isOwner(incoming().userId) || isAdmin()) && 
                      (isAdmin() || isNotBanned()) && 
                      isValidTransaction(incoming());
      // Transactions are immutable
      allow update, delete: if false;
    }

    match /boxOpenings/{openingId} {
      allow read: if isAuthenticated();
      allow create: if isNotBanned() && isOwner(incoming().userId);
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /quizAttempts/{attemptId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isNotBanned() && isOwner(incoming().userId);
    }

    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidAppSettings(incoming());
    }
  }
}
